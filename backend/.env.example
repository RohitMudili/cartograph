# Copy to .env and fill in. .env is gitignored — never commit real keys.

# ── Gemini ───────────────────────────────────────────────────────────────────
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── Database ─────────────────────────────────────────────────────────────────
# Matches the docker-compose Postgres service. Override if using local Postgres.
DATABASE_URL=postgresql+asyncpg://cartograph:cartograph@localhost:5432/cartograph

# ── App ──────────────────────────────────────────────────────────────────────
CARTOGRAPH_ENV=local
LOG_LEVEL=INFO

# ── Budgets / limits (safe defaults; tune per PLAN.md §7) ────────────────────
# Hard ceiling per index run, in USD — run aborts gracefully if exceeded.
MAX_RUN_COST_USD=2.00
# Repo size guardrails (PLAN.md §9 security).
MAX_REPO_FILES=5000
MAX_REPO_MB=500
# Concurrent explorer agents (PLAN.md §4.2).
MAX_AGENT_CONCURRENCY=6
# Allowed git hosts for cloning (comma-separated).
ALLOWED_GIT_HOSTS=github.com
