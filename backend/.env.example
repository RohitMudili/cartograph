# Copy to .env and fill in. .env is gitignored — never commit real keys.

# ── Models (provider-agnostic via LangChain init_chat_model) ─────────────────
# Format: "<provider>:<model>"  (provider ∈ google_genai | openai | anthropic)
# Swap a tier's provider here — no code changes needed.
REASONING_MODEL=google_genai:gemini-3.5-flash
FAST_MODEL=google_genai:gemini-3.1-flash-lite
EMBEDDING_MODEL=google_genai:gemini-embedding-2

# ── Provider API keys ────────────────────────────────────────────────────────
# Set the key(s) for whichever providers your model strings above use.
# Google: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here
# OpenAI (only if using openai: models): https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key-here
# Anthropic (only if using anthropic: models): https://console.anthropic.com/
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Database ─────────────────────────────────────────────────────────────────
# Matches the docker-compose Postgres service. Override if using local Postgres.
DATABASE_URL=postgresql+asyncpg://cartograph:cartograph@localhost:5432/cartograph

# ── App ──────────────────────────────────────────────────────────────────────
CARTOGRAPH_ENV=local
LOG_LEVEL=INFO

# ── Budgets / limits (safe defaults; tune per PLAN.md §7) ────────────────────
# Hard ceiling per index run, in USD — run aborts gracefully if exceeded.
MAX_RUN_COST_USD=2.00
# Repo size guardrails (PLAN.md §9 security).
MAX_REPO_FILES=5000
MAX_REPO_MB=500
# Concurrent explorer agents (PLAN.md §4.2).
MAX_AGENT_CONCURRENCY=6
# Allowed git hosts for cloning (comma-separated).
ALLOWED_GIT_HOSTS=github.com
