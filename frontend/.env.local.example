# Copy to .env.local. Public env vars (NEXT_PUBLIC_*) are exposed to the browser.

# Backend API base URL (FastAPI dev server).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase Auth (Google sign-in). From Supabase → Project Settings → API.
# The anon key is the PUBLIC client key — safe in the browser (NOT the service key).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
